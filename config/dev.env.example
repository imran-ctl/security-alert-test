# Copy this file to config/dev.env and fill in your actual values.
# NEVER commit config/dev.env — it is listed in .gitignore.
# Obtain real values from your team's secrets manager (e.g. AWS Secrets Manager,
# HashiCorp Vault) or from the relevant provider dashboards.

GITHUB_TOKEN=<your-github-token>
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
STRIPE_SECRET_KEY=<your-stripe-secret-key>
